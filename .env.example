# Alpaca API Credentials (Paper Trading)
APCA_API_KEY_ID=your_api_key_id_here
APCA_API_SECRET_KEY=your_api_secret_key_here
APCA_API_BASE_URL=https://paper-api.alpaca.markets
GEMINI_API_KEY=your_gemini_api_key_here

# Trading Configuration
TRADE_AMOUNT_USD=5.00
LOG_LEVEL=INFO

# Telegram Notifications (optional — leave empty to disable)
# Setup: create a bot via @BotFather, then get your chat_id from:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
